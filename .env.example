# ---- Base de datos ----
DB_USER=briefings
DB_PASSWORD=cambiar_en_local
DB_NAME=briefings
DATABASE_URL=postgresql+psycopg://briefings:cambiar_en_local@db:5432/briefings

# ---- Cola asíncrona ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ---- Object storage ----
MINIO_USER=minioadmin
MINIO_PASSWORD=cambiar_en_local
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=fuentes
MINIO_SECURE=false
# Cifrado en reposo de los binarios (envelope client-side con ENCRYPTION_KEY, RNF-002)
MINIO_ENCRYPT=true

# ---- LDAP / AD ----
LDAP_ADMIN_USER=admin
LDAP_ADMIN_PASSWORD=cambiar_en_local
LDAP_DEMO_PASSWORD=demo1234
LDAP_HOST=openldap
LDAP_PORT=1389
LDAP_BASE_DN=dc=ejercito,dc=cl
LDAP_USER_DN_TEMPLATE=cn={username},ou=users,dc=ejercito,dc=cl

# ---- Seguridad ----
JWT_SECRET=generar_uno_largo_y_aleatorio
JWT_ALGORITHM=HS256
SESSION_TIMEOUT_MIN=15
# Cifrado en reposo (RNF-002): 32 bytes en base64 -> openssl rand -base64 32
ENCRYPTION_KEY=clave_aes_256_base64
# Auditar también lecturas/consultas de clasificado (RNF-003)
AUDIT_LOG_READS=true
AUDIT_RETENTION_YEARS=5

# ---- LLM (proveedor intercambiable) ----
# LLM_PROVIDER: github | groq | local
LLM_PROVIDER=github
# GitHub Models (gpt-4o) — token = PAT de GitHub con permiso de Models
GITHUB_TOKEN=
GITHUB_BASE_URL=https://models.github.ai/inference
GITHUB_MODEL=openai/gpt-4o
LLM_MAX_RETRIES=4
# Groq (legado)
GROQ_API_KEY=gsk_xxx
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_RETRIES=3
# Embeddings locales (on-premise) para RF-005
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ---- Reglas de detección (RF-005) ----
# DEDUP_THRESHOLD: similitud coseno para considerar duplicado
DEDUP_THRESHOLD=0.85
# DESACTUALIZADO_DIAS: antigüedad para marcar un hecho como desactualizado
DESACTUALIZADO_DIAS=7

# ---- Exportación (RF-008) ----
# EXPORT_STYLE: overlay (pixel-perfect sobre la plantilla PNG) | flow (reconstrucción HTML)
EXPORT_STYLE=overlay
# EXPORT_DEBUG_GRID: dibuja una rejilla del 10% para calibrar las coordenadas del overlay
EXPORT_DEBUG_GRID=false

# ---- Frontend ----
VITE_API_URL=https://localhost/api
VITE_WS_URL=wss://localhost/ws
